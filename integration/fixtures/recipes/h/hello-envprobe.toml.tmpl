[package]
name = "hello-envprobe"
version = "1.0"
description = "integration test fixture — emits build-time $HOME"
license = "MIT"

[source]
url = "__GHCR_URL__/blobs/source/hello-src.tar.zst"
sha256 = "__HELLO_SRC_PAYLOAD_SHA__"

[build]
steps = [
  "mkdir -p ${PREFIX}/bin",
  "printf '%s\\n' \"$HOME\" > ${PREFIX}/bin/gale-home.txt",
]
